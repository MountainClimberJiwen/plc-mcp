{
  "name": "scl-runner",
  "displayName": "SCL Runner",
  "description": "A VS Code extension to run SCL files.",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/scl-runner.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:scl"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "scl",
        "extensions": [
          ".scl"
        ],
        "aliases": [
          "SCL"
        ]
      }
    ],
    "commands": [
      {
        "command": "scl-runner.runScl",
        "title": "Run SCL File"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "scl-runner.runScl",
          "title": "Run PLC"
        }
      ],
      "explorer/context": [
        {
          "command": "scl-runner.runScl",
          "title": "Run PLC"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "typescript": "^4.4.3",
    "vscode-test": "^1.5.2"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
